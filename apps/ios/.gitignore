# XcodeGen output — regenerate with `xcodegen generate`
FreshPantry.xcodeproj/
# Track Package.resolved for reproducible CI dependency resolution.
# Run `git add -f FreshPantry.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved`
# once after xcodegen generate to commit the current lockfile.
!FreshPantry.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
!FreshPantry.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# Xcode
build/
DerivedData/
*.xcuserstate
xcuserdata/
.swiftpm/
*.swift.orig

# Secrets — generated from CI secrets or copied from Secrets.example.plist
FreshPantry/Support/Secrets.plist

# Recipe covers — hosted on Supabase Storage (recipe-images bucket), not bundled.
# Kept on disk only as the pipeline's upload source (npm run images:upload);
# not tracked to avoid ~111MB in the tree. See apps/recipe-pipeline/README.md.
FreshPantry/Resources/RecipeImages/

# macOS
.DS_Store
